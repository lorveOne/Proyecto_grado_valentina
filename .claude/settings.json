{
  "permissions": {
    "allow": [
      "PowerShell(git config user.name)",
      "PowerShell(git config user.email)",
      "PowerShell(Invoke-WebRequest -Uri \"http://localhost:8000/\" -UseBasicParsing -Method Head)",
      "PowerShell(try { \\(Invoke-WebRequest -Uri \"http://localhost:8000/\" -UseBasicParsing -Method Head -TimeoutSec 5\\).StatusCode } catch { \"Error: $_\" })",
      "PowerShell(Start-Process \"http://localhost:8000/\")",
      "PowerShell(git config --global --get credential.helper)",
      "PowerShell(git config --system --get credential.helper)",
      "PowerShell(python -m http.server 8000)",
      "PowerShell(try { \\(Invoke-WebRequest -Uri \"http://localhost:8000/\" -UseBasicParsing -Method Head -TimeoutSec 5\\).StatusCode } catch { \"Error: $_\" }; Start-Process \"http://localhost:8000/\")",
      "PowerShell(python -m http.server 5500)",
      "PowerShell(try { \\(Invoke-WebRequest -Uri \"http://localhost:5500/\" -UseBasicParsing -Method Head -TimeoutSec 5\\).StatusCode } catch { \"Error: $_\" }; Start-Process \"http://localhost:5500/#checklist\")"
    ]
  }
}
